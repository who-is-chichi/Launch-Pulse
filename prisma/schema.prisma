datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("viewer")
  orgId        String   @default("org_default")
  tokenVersion Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Brand {
  id                 String               @id @default(cuid())
  code               String               @unique
  name               String
  orgId              String   @default("org_default")
  dataRuns           DataRun[]
  insights           Insight[]
  actions            Action[]
  kpiTiles           KpiTile[]
  goldInputSnapshots GoldInputSnapshot[]
  claimsMetrics      ClaimsMetricsFact[]
  spMetrics          SpMetricsFact[]
  callsMetrics       CallsMetricsFact[]
  structureChanges   StructureChangeLog[]
  territoryChanges   TerritoryChangeLog[]
  mappingConfigs     MappingConfig[]
  normalizationRules NormalizationRule[]
  publishedMappings  PublishedMapping[]
  crosswalkStats     CrosswalkStat[]
  // Bronze control
  bronzeIngestionRuns        BronzeCtlIngestionRun[]
  bronzeFileManifests        BronzeCtlFileManifest[]
  bronzeRowRejections        BronzeCtlRowRejection[]
  bronzeSchemaRegistry       BronzeCtlSchemaRegistry[]
  bronzeMappingIssues        BronzeCtlMappingValidationIssue[]
  bronzeUnmappedFields       BronzeCtlUnmappedFieldsRegistry[]
  // Bronze raw
  bronzeClaimsRaw            BronzeClaimsRaw[]
  bronzeSpCasesRaw           BronzeSpCasesRaw[]
  bronzeSpStatusHistoryRaw   BronzeSpStatusHistoryRaw[]
  bronzeDispenseRaw          BronzeDispenseRaw[]
  bronzeShipmentsRaw         BronzeShipmentsRaw[]
  bronzeCallsRaw             BronzeCallsRaw[]
  bronzeHcpMasterRaw         BronzeHcpMasterRaw[]
  bronzeHcoMasterRaw         BronzeHcoMasterRaw[]
  bronzeAffiliationsRaw      BronzeAffiliationsRaw[]
  bronzeTerritoryAlignmentRaw BronzeTerritoryAlignmentRaw[]
  bronzeRepRosterRaw         BronzeRepRosterRaw[]
}

model DataRun {
  id                 String               @id @default(cuid())
  brandId            String
  brand              Brand                @relation(fields: [brandId], references: [id])
  runAt              DateTime
  timeWindow         String
  geography          String
  status             String               @default("complete")
  datasets           Dataset[]
  kpiTiles           KpiTile[]
  insights           Insight[]
  goldInputSnapshots GoldInputSnapshot[]

  @@index([brandId, runAt])
}

model Dataset {
  id          String   @id @default(cuid())
  dataRunId   String
  dataRun     DataRun  @relation(fields: [dataRunId], references: [id])
  name        String
  displayName String
  lastRun     DateTime
  freshness   String
  coverage    Float
  notes       String
}

model KpiTile {
  id        String  @id @default(cuid())
  brandId   String
  brand     Brand   @relation(fields: [brandId], references: [id])
  dataRunId String
  dataRun   DataRun @relation(fields: [dataRunId], references: [id])
  title     String
  value     String
  delta     String
  deltaType String
  sparkline Int[]
  sortOrder Int     @default(0)
}

model Insight {
  id            String         @id @default(cuid())
  brandId       String
  brand         Brand          @relation(fields: [brandId], references: [id])
  dataRunId     String
  dataRun       DataRun        @relation(fields: [dataRunId], references: [id])
  headline      String
  pillar        String
  severity      String
  confidence    String
  impact        String
  region        String
  status        String         @default("New")
  notes         String?        // user-editable notes (saved via PATCH)
  generatedDate DateTime       @default(now())
  createdBy     String?        // future RBAC — user/system that generated this insight
  drivers       Driver[]
  metricChanges MetricChange[]
  contributors  Contributor[]
  risks         InsightRisk[]
  actions       Action[]

  @@index([dataRunId, severity])
  @@index([brandId, dataRunId])
}

model Driver {
  id          String  @id @default(cuid())
  insightId   String
  insight     Insight @relation(fields: [insightId], references: [id])
  label       String
  confidence  Int
  description String
  sortOrder   Int     @default(0)

  @@index([insightId])
}

model MetricChange {
  id            String  @id @default(cuid())
  insightId     String
  insight       Insight @relation(fields: [insightId], references: [id])
  metric        String
  before        String
  after         String
  change        String
  changePercent String
  direction     String

  @@index([insightId])
}

model Contributor {
  id        String  @id @default(cuid())
  insightId String
  insight   Insight @relation(fields: [insightId], references: [id])
  entity    String
  type      String
  impact    String
  percent   String
  sortOrder Int     @default(0)

  @@index([insightId])
}

model InsightRisk {
  id        String  @id @default(cuid())
  insightId String
  insight   Insight @relation(fields: [insightId], references: [id])
  risk      String
  sortOrder Int     @default(0)

  @@index([insightId])
}

model Action {
  id            String       @id @default(cuid())
  brandId       String
  brand         Brand        @relation(fields: [brandId], references: [id])
  insightId     String?
  insight       Insight?     @relation(fields: [insightId], references: [id])
  title         String
  linkedInsight String
  owner         String
  ownerRole     String?      // e.g. "Regional Sales Director"
  dueDate       DateTime
  severity      String
  expectedLag   String
  status        String       @default("new")
  notes         String?      // additional context or instructions
  createdAt     DateTime     @default(now())
  createdBy     String?      // future RBAC — user who created this action
  impactScore   ImpactScore?
}

model ImpactScore {
  id                 String   @id @default(cuid())
  actionId           String   @unique
  action             Action   @relation(fields: [actionId], references: [id])
  // Manual entry fields (used by UI — keep for backward compat)
  metric             String
  before             String
  after              String
  change             String
  outcome            String
  completedDate      DateTime
  // Auto-evaluation fields (written by evaluateActions)
  baselineDataRunId  String?
  evaluatedDataRunId String?
  metricKey          String?
  baselineValue      Float?
  currentValue       Float?
  autoEvaluated      Boolean  @default(false)
}

model GoldInputSnapshot {
  id            String   @id @default(cuid())
  brandId       String
  brand         Brand    @relation(fields: [brandId], references: [id])
  dataRunId     String
  dataRun       DataRun  @relation(fields: [dataRunId], references: [id])
  snapshotDate  DateTime
  metric        String
  dimension     String
  dimensionType String
  currentValue  Float
  priorValue    Float
  unit          String

  @@index([brandId, dataRunId])
  @@index([brandId, metric, dimension])
}

model ClaimsMetricsFact {
  id                String   @id @default(cuid())
  brandId           String
  brand             Brand    @relation(fields: [brandId], references: [id])
  weekEnding        DateTime
  dimension         String
  dimensionType     String
  nrxCount          Int
  marketSharePct    Float?
  activePrescribers Int?

  @@index([brandId, weekEnding])
  @@index([brandId, dimensionType])
}

model SpMetricsFact {
  id                   String   @id @default(cuid())
  brandId              String
  brand                Brand    @relation(fields: [brandId], references: [id])
  recordDate           DateTime
  pendingOutreachCount Int
  resolutionTimeMedian Float
  tttMedianDays        Float

  @@index([brandId, recordDate])
}

model CallsMetricsFact {
  id                 String   @id @default(cuid())
  brandId            String
  brand              Brand    @relation(fields: [brandId], references: [id])
  weekEnding         DateTime
  territory          String
  compliancePct      Float
  repsTotal          Int
  repsBelowThreshold Int

  @@index([brandId, weekEnding])
}

model StructureChangeLog {
  id           String   @id @default(cuid())
  brandId      String
  brand        Brand    @relation(fields: [brandId], references: [id])
  eventDate    DateTime
  eventType    String
  payerName    String
  region       String
  coveredLives Int
}

model TerritoryChangeLog {
  id           String   @id @default(cuid())
  brandId      String
  brand        Brand    @relation(fields: [brandId], references: [id])
  changeDate   DateTime
  territory    String
  changeType   String   // 'realignment' | 'vacancy' | 'new_hire'
  affectedReps Int
  region       String

  @@index([brandId, changeDate])
}

model MappingConfig {
  id          String   @id @default(cuid())
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id])
  dataset     String
  status      String   @default("Configured")
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NormalizationRule {
  id              String   @id @default(cuid())
  brandId         String
  brand           Brand    @relation(fields: [brandId], references: [id])
  ruleType        String   @default("sp_status")
  hubValue        String
  normalizedValue String
  category        String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PublishedMapping {
  id          String   @id @default(cuid())
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id])
  name        String
  dataset     String
  publishedBy String
  publishedAt DateTime @default(now())
  fieldCount  Int      @default(0)
  status      String   @default("Active")
  createdAt   DateTime @default(now())
}

model CrosswalkStat {
  id             String   @id @default(cuid())
  brandId        String
  brand          Brand    @relation(fields: [brandId], references: [id])
  statType       String
  label          String
  matchRate      Float
  unmatchedCount Int      @default(0)
  entityType     String   @default("")
  updatedAt      DateTime @updatedAt

  @@index([brandId])
}

model UserPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  notifyHighSeverity  Boolean  @default(true)
  notifyActionsDue    Boolean  @default(true)
  notifyWeeklySummary Boolean  @default(false)
  notifyDataFreshness Boolean  @default(true)
  defaultBrand        String   @default("ONC-101")
  defaultTimeWindow   String   @default("Last 7 days")
  defaultGeography    String   @default("Nation")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─────────────────────────────────────────────
// BRONZE CONTROL / OPS TABLES
// ─────────────────────────────────────────────

model BronzeCtlIngestionRun {
  id                 String    @id @default(cuid())
  clientId           String
  brandId            String?
  brand              Brand?    @relation(fields: [brandId], references: [id])
  runType            String    @default("full")     // full | incremental | replay | backfill
  sourceSystem       String
  sourceFeedName     String
  triggerType        String    @default("api")      // schedule | manual | api | replay
  pipelineVersion    String?
  orchestratorJobId  String?
  startedAt          DateTime  @default(now())
  endedAt            DateTime?
  status             String    @default("running")  // running | success | partial_success | failed
  filesDetected      Int       @default(0)
  filesLoaded        Int       @default(0)
  recordsRead        BigInt    @default(0)
  recordsLoaded      BigInt    @default(0)
  recordsRejected    BigInt    @default(0)
  errorCount         Int       @default(0)
  errorSummary       String?
  metadata           Json?
  createdBy          String?
  createdAt          DateTime  @default(now())
  fileManifests      BronzeCtlFileManifest[]
  rowRejections      BronzeCtlRowRejection[]
  mappingIssues      BronzeCtlMappingValidationIssue[]

  @@index([clientId, startedAt])
  @@index([brandId])
}

model BronzeCtlFileManifest {
  id                      String                @id @default(cuid())
  ingestionRunId          String
  ingestionRun            BronzeCtlIngestionRun @relation(fields: [ingestionRunId], references: [id])
  clientId                String
  brandId                 String?
  brand                   Brand?                @relation(fields: [brandId], references: [id])
  sourceSystem            String
  sourceFeedName          String
  brandCode               String?
  sourceFileName          String
  sourceFilePath          String                @default("")
  fileType                String                @default("json")  // csv | xlsx | json | parquet
  compressionType         String?
  fileSizeBytes           BigInt?
  checksumMd5             String?
  checksumSha256          String?
  sourceFileDate          DateTime?
  sourceDropTs            DateTime?
  receivedTs              DateTime              @default(now())
  headerRow               Json?
  rowCountRaw             BigInt?
  rowCountLoaded          BigInt                @default(0)
  rowCountRejected        BigInt                @default(0)
  schemaVersionDetected   String?
  status                  String                @default("received")  // received | parsed | loaded | partial | failed | archived
  errorSummary            String?
  archivedFlag            Boolean               @default(false)
  createdAt               DateTime              @default(now())
  rowRejections           BronzeCtlRowRejection[]
  unmappedFields          BronzeCtlUnmappedFieldsRegistry[]

  @@index([clientId, receivedTs])
  @@index([ingestionRunId])
}

model BronzeCtlRowRejection {
  id               String                @id @default(cuid())
  ingestionRunId   String
  ingestionRun     BronzeCtlIngestionRun @relation(fields: [ingestionRunId], references: [id])
  fileManifestId   String?
  fileManifest     BronzeCtlFileManifest? @relation(fields: [fileManifestId], references: [id])
  clientId         String
  brandId          String?
  brand            Brand?                @relation(fields: [brandId], references: [id])
  sourceSystem     String
  sourceFeedName   String
  datasetName      String
  sourceFileName   String?
  sourceRowNumber  BigInt?
  sourcePrimaryKey String?
  rejectionStage   String                // parse | schema | required_field | type_cast | mapping
  rejectionCode    String
  rejectionReason  String
  rawPayload       Json
  createdAt        DateTime              @default(now())

  @@index([clientId, ingestionRunId])
  @@index([brandId])
}

model BronzeCtlSchemaRegistry {
  id                String   @id @default(cuid())
  clientId          String
  brandId           String?
  brand             Brand?   @relation(fields: [brandId], references: [id])
  sourceSystem      String
  sourceFeedName    String
  datasetName       String
  schemaVersion     String
  columnDefinitions Json
  detectedAt        DateTime @default(now())
  activeFlag        Boolean  @default(true)
  notes             String?

  @@index([clientId, sourceSystem, sourceFeedName])
  @@index([brandId])
}

model BronzeCtlMappingValidationIssue {
  id               String                @id @default(cuid())
  ingestionRunId   String
  ingestionRun     BronzeCtlIngestionRun @relation(fields: [ingestionRunId], references: [id])
  fileManifestId   String?
  clientId         String
  brandId          String?
  brand            Brand?                @relation(fields: [brandId], references: [id])
  datasetName      String
  issueLevel       String                // warning | error
  issueType        String                // missing_required_field | duplicate_mapping | bad_transform | unknown_column
  sourceColumnName String?
  targetFieldName  String?
  issueMessage     String
  issueDetails     Json?
  createdAt        DateTime              @default(now())

  @@index([clientId, ingestionRunId])
  @@index([brandId])
}

model BronzeCtlUnmappedFieldsRegistry {
  id               String                 @id @default(cuid())
  clientId         String
  brandId          String?
  brand            Brand?                 @relation(fields: [brandId], references: [id])
  datasetName      String
  sourceSystem     String
  sourceFeedName   String
  fileManifestId   String?
  fileManifest     BronzeCtlFileManifest? @relation(fields: [fileManifestId], references: [id])
  sourceColumnName String
  sampleValues     Json?
  firstSeenAt      DateTime               @default(now())
  lastSeenAt       DateTime               @default(now())
  status           String                 @default("unreviewed")  // unreviewed | accepted_extra | map_later | ignored
  notes            String?

  @@index([clientId, datasetName])
  @@index([brandId])
}

// ─────────────────────────────────────────────
// BRONZE RAW BUSINESS TABLES
// Common metadata block on every table:
//   bronzeRecordId (= id), clientId, brandId, datasetName,
//   sourceSystem, sourceFeedName, ingestionRunId, fileManifestId,
//   sourceFileName, sourceFilePath, sourceRowNumber, sourcePrimaryKey,
//   sourceExtractTs, sourceRecordTs, opType, isDeletedFlag,
//   schemaVersion, recordHash, rawPayload, parseStatus,
//   parseErrorCode, parseErrorDetail, partitionDate, loadedAt, createdAt
// ─────────────────────────────────────────────

model BronzeClaimsRaw {
  id               String    @id @default(cuid())
  clientId         String
  brandId          String?
  brand            Brand?    @relation(fields: [brandId], references: [id])
  datasetName      String    @default("claims")
  sourceSystem     String
  sourceFeedName   String
  ingestionRunId   String
  fileManifestId   String?
  sourceFileName   String?
  sourceFilePath   String?
  sourceRowNumber  BigInt?
  sourcePrimaryKey String?
  sourceExtractTs  DateTime?
  sourceRecordTs   DateTime?
  opType           String?
  isDeletedFlag    Boolean   @default(false)
  schemaVersion    String?
  recordHash       String
  rawPayload       Json
  parseStatus      String    @default("parsed")  // parsed | partial | failed
  parseErrorCode   String?
  parseErrorDetail String?
  partitionDate    DateTime  @default(now())
  loadedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  // Source-specific columns
  claimId           String?
  claimLineId       String?
  patientToken      String?
  patientAgeBand    String?
  patientGender     String?
  payerChannel      String?
  payerNameRaw      String?
  planNameRaw       String?
  planIdRaw         String?
  pbmNameRaw        String?
  drugNameRaw       String?
  brandNameRaw      String?
  ndc11             String?
  trxNrxFlag        String?
  rxFillNumber      Int?
  quantity          Decimal?  @db.Decimal(18, 4)
  daysSupply        Int?
  writtenDate       DateTime?
  fillDate          DateTime?
  serviceDate       DateTime?
  prescriberNpiRaw  String?
  prescriberIdRaw   String?
  hcpNameRaw        String?
  hcoIdRaw          String?
  hcoNameRaw        String?
  specialtyRaw      String?
  zip3              String?
  zip5              String?
  stateCode         String?
  territoryCodeRaw  String?
  claimStatusRaw    String?
  rejectionCodeRaw  String?
  rejectionReasonRaw String?
  paidAmountRaw     Decimal?  @db.Decimal(18, 4)
  copayAmountRaw    Decimal?  @db.Decimal(18, 4)
  sourceLastUpdatedTs DateTime?

  @@index([brandId, fillDate])
  @@index([brandId, ingestionRunId])
  @@index([clientId, partitionDate])
}

model BronzeSpCasesRaw {
  id               String    @id @default(cuid())
  clientId         String
  brandId          String?
  brand            Brand?    @relation(fields: [brandId], references: [id])
  datasetName      String    @default("sp_cases")
  sourceSystem     String
  sourceFeedName   String
  ingestionRunId   String
  fileManifestId   String?
  sourceFileName   String?
  sourceFilePath   String?
  sourceRowNumber  BigInt?
  sourcePrimaryKey String?
  sourceExtractTs  DateTime?
  sourceRecordTs   DateTime?
  opType           String?
  isDeletedFlag    Boolean   @default(false)
  schemaVersion    String?
  recordHash       String
  rawPayload       Json
  parseStatus      String    @default("parsed")
  parseErrorCode   String?
  parseErrorDetail String?
  partitionDate    DateTime  @default(now())
  loadedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  // Source-specific
  spCaseId              String?
  referralId            String?
  patientToken          String?
  prescriberNpiRaw      String?
  prescriberIdRaw       String?
  hcpNameRaw            String?
  hcoIdRaw              String?
  hcoNameRaw            String?
  brandNameRaw          String?
  drugNameRaw           String?
  caseStatusRaw         String?
  caseSubstatusRaw      String?
  casePriorityRaw       String?
  referralDate          DateTime?
  intakeDate            DateTime?
  bvStartDate           DateTime?
  bvCompleteDate        DateTime?
  paStartDate           DateTime?
  paOutcomeDate         DateTime?
  patientOutreachDate   DateTime?
  approvalDate          DateTime?
  firstDispenseDateRaw  DateTime?
  shipmentDateRaw       DateTime?
  abandonmentDate       DateTime?
  closureDate           DateTime?
  hubVendorRaw          String?
  pharmacyNameRaw       String?
  pharmacyIdRaw         String?
  payerNameRaw          String?
  planNameRaw           String?
  planIdRaw             String?
  rejectionReasonRaw    String?
  supportProgramRaw     String?
  sourceLastUpdatedTs   DateTime?

  @@index([brandId, referralDate])
  @@index([brandId, ingestionRunId])
  @@index([clientId, partitionDate])
}

model BronzeSpStatusHistoryRaw {
  id               String    @id @default(cuid())
  clientId         String
  brandId          String?
  brand            Brand?    @relation(fields: [brandId], references: [id])
  datasetName      String    @default("sp_status_history")
  sourceSystem     String
  sourceFeedName   String
  ingestionRunId   String
  fileManifestId   String?
  sourceFileName   String?
  sourceFilePath   String?
  sourceRowNumber  BigInt?
  sourcePrimaryKey String?
  sourceExtractTs  DateTime?
  sourceRecordTs   DateTime?
  opType           String?
  isDeletedFlag    Boolean   @default(false)
  schemaVersion    String?
  recordHash       String
  rawPayload       Json
  parseStatus      String    @default("parsed")
  parseErrorCode   String?
  parseErrorDetail String?
  partitionDate    DateTime  @default(now())
  loadedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  // Source-specific
  spStatusEventId    String?
  spCaseId           String?
  statusRaw          String?
  substatusRaw       String?
  statusEffectiveTs  DateTime?
  statusEndTs        DateTime?
  changedByRaw       String?
  changeReasonRaw    String?
  eventSequence      Int?
  sourceLastUpdatedTs DateTime?

  @@index([brandId, ingestionRunId])
  @@index([clientId, partitionDate])
}

model BronzeDispenseRaw {
  id               String    @id @default(cuid())
  clientId         String
  brandId          String?
  brand            Brand?    @relation(fields: [brandId], references: [id])
  datasetName      String    @default("dispense")
  sourceSystem     String
  sourceFeedName   String
  ingestionRunId   String
  fileManifestId   String?
  sourceFileName   String?
  sourceFilePath   String?
  sourceRowNumber  BigInt?
  sourcePrimaryKey String?
  sourceExtractTs  DateTime?
  sourceRecordTs   DateTime?
  opType           String?
  isDeletedFlag    Boolean   @default(false)
  schemaVersion    String?
  recordHash       String
  rawPayload       Json
  parseStatus      String    @default("parsed")
  parseErrorCode   String?
  parseErrorDetail String?
  partitionDate    DateTime  @default(now())
  loadedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  // Source-specific
  dispenseId                String?
  spCaseId                  String?
  patientToken              String?
  prescriberNpiRaw          String?
  ndc11                     String?
  brandNameRaw              String?
  dispenseDate              DateTime?
  shipDate                  DateTime?
  fillNumber                Int?
  quantity                  Decimal?  @db.Decimal(18, 4)
  daysSupply                Int?
  dispensingPharmacyIdRaw   String?
  dispensingPharmacyNameRaw String?
  dispenseStatusRaw         String?
  dispenseChannelRaw        String?
  sourceLastUpdatedTs       DateTime?

  @@index([brandId, dispenseDate])
  @@index([brandId, ingestionRunId])
  @@index([clientId, partitionDate])
}

model BronzeShipmentsRaw {
  id               String    @id @default(cuid())
  clientId         String
  brandId          String?
  brand            Brand?    @relation(fields: [brandId], references: [id])
  datasetName      String    @default("shipments")
  sourceSystem     String
  sourceFeedName   String
  ingestionRunId   String
  fileManifestId   String?
  sourceFileName   String?
  sourceFilePath   String?
  sourceRowNumber  BigInt?
  sourcePrimaryKey String?
  sourceExtractTs  DateTime?
  sourceRecordTs   DateTime?
  opType           String?
  isDeletedFlag    Boolean   @default(false)
  schemaVersion    String?
  recordHash       String
  rawPayload       Json
  parseStatus      String    @default("parsed")
  parseErrorCode   String?
  parseErrorDetail String?
  partitionDate    DateTime  @default(now())
  loadedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  // Source-specific
  shipmentId               String?
  spCaseId                 String?
  orderIdRaw               String?
  patientToken             String?
  brandNameRaw             String?
  ndc11                    String?
  shipmentDate             DateTime?
  deliveryDateRaw          DateTime?
  shipmentStatusRaw        String?
  shipmentQuantity         Decimal?  @db.Decimal(18, 4)
  daysSupplyRaw            Int?
  shippingPharmacyIdRaw    String?
  shippingPharmacyNameRaw  String?
  carrierRaw               String?
  trackingNumberRaw        String?
  sourceLastUpdatedTs      DateTime?

  @@index([brandId, shipmentDate])
  @@index([brandId, ingestionRunId])
  @@index([clientId, partitionDate])
}

model BronzeCallsRaw {
  id               String    @id @default(cuid())
  clientId         String
  brandId          String?
  brand            Brand?    @relation(fields: [brandId], references: [id])
  datasetName      String    @default("calls")
  sourceSystem     String
  sourceFeedName   String
  ingestionRunId   String
  fileManifestId   String?
  sourceFileName   String?
  sourceFilePath   String?
  sourceRowNumber  BigInt?
  sourcePrimaryKey String?
  sourceExtractTs  DateTime?
  sourceRecordTs   DateTime?
  opType           String?
  isDeletedFlag    Boolean   @default(false)
  schemaVersion    String?
  recordHash       String
  rawPayload       Json
